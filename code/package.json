{
	"name": "room-food",
	"version": "0.0.0",
	"scripts": {
		"build": "ng build --configuration production --output-hashing none && node scripts/postprocess-index.js",
		"frontend:build": "npm run build",
		"frontend:start": "ng serve --proxy-config proxy.conf.json",
		"backend:build": "ng run roomFood:build:production",
		"backend:dev": "npx tsx src/backend/start-api.ts",
		"backend:start": "cross-env SERVE_FRONTEND=false node dist/roomFood/server/server.mjs",
		"test": "ng test",
		"init-db": "npx tsx src/backend/init-db.ts"
	},
	"prettier": {
		"printWidth": 100,
		"singleQuote": true,
		"overrides": [
			{
				"files": "*.html",
				"options": {
					"parser": "angular"
				}
			}
		]
	},
	"private": true,
	"packageManager": "npm@10.9.3",
	"dependencies": {
		"@angular/cdk": "^20.2.14",
		"@angular/common": "^20.3.18",
		"@angular/compiler": "^20.3.18",
		"@angular/core": "^20.3.18",
		"@angular/forms": "^20.3.18",
		"@angular/material": "^20.2.14",
		"@angular/platform-browser": "^20.3.18",
		"@angular/platform-server": "^20.3.18",
		"@angular/router": "^20.3.18",
		"@angular/ssr": "^20.3.20",
		"bcryptjs": "^3.0.3",
		"better-sqlite3": "^12.6.2",
		"cookie-parser": "^1.4.7",
		"dotenv": "^17.4.2",
		"express": "^5.1.0",
		"http-status-codes": "^2.3.0",
		"jsonwebtoken": "^9.0.3",
		"rxjs": "~7.8.0",
		"tslib": "^2.3.0",
		"zone.js": "~0.15.1"
	},
	"devDependencies": {
		"@angular/build": "^20.3.20",
		"@angular/cli": "^20.3.20",
		"@angular/compiler-cli": "^20.3.18",
		"@types/bcrypt": "^6.0.0",
		"@types/bcryptjs": "^2.4.6",
		"@types/better-sqlite3": "^7.6.13",
		"@types/cookie-parser": "^1.4.10",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.1",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/node": "^20.19.33",
		"cors": "^2.8.6",
		"cross-env": "^7.0.3",
		"jsdom": "^27.1.0",
		"ts-node": "^10.9.2",
		"typescript": "~5.9.2",
		"vitest": "^3.2.4"
	}
}
